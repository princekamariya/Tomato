# Copy to `.env` or `.env.local` and fill in real values.
# Restart `npm run dev` after changes.

# Google OAuth Web client ID (from Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Auth API base URL (optional; defaults to http://localhost:3000 in src/config/authService.ts)
# VITE_AUTH_SERVICE_URL=http://localhost:3000
